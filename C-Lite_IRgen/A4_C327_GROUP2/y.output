Grammar

    0 $accept: program $end

    1 program: translation_unit

    2 translation_unit: external_decl
    3                 | translation_unit external_decl

    4 external_decl: function_def
    5              | declaration

    6 function_def: function_header compound_stmt

    7 $@1: ε

    8 function_header: type_spec IDENTIFIER '(' $@1 param_list ')'

    9 $@2: ε

   10 function_header: type_spec IDENTIFIER '(' $@2 ')'

   11 $@3: ε

   12 function_header: storage_class_list type_spec IDENTIFIER '(' $@3 param_list ')'

   13 $@4: ε

   14 function_header: storage_class_list type_spec IDENTIFIER '(' $@4 ')'

   15 param_list: param_decl
   16           | param_list ',' param_decl
   17           | ELLIPSIS
   18           | param_list ',' ELLIPSIS

   19 param_decl: type_spec IDENTIFIER
   20           | type_spec '*' IDENTIFIER
   21           | type_spec IDENTIFIER '[' ']'
   22           | type_spec IDENTIFIER '[' INT_CONST ']'
   23           | type_spec

   24 $@5: ε

   25 declaration: type_spec $@5 declarator_list ';'

   26 $@6: ε

   27 declaration: storage_class_list type_spec $@6 declarator_list ';'
   28            | type_spec ';'
   29            | storage_class_list type_spec ';'

   30 $@7: ε

   31 declaration: TYPEDEF type_spec $@7 declarator_list ';'
   32            | struct_decl ';'
   33            | enum_decl ';'

   34 declarator_list: declarator
   35                | declarator_list ',' declarator

   36 declarator: IDENTIFIER
   37           | IDENTIFIER '=' initializer
   38           | '*' IDENTIFIER
   39           | '*' IDENTIFIER '=' initializer
   40           | IDENTIFIER '[' INT_CONST ']'
   41           | IDENTIFIER '[' ']'
   42           | IDENTIFIER '(' param_list ')'
   43           | IDENTIFIER '(' ')'
   44           | '(' '*' IDENTIFIER ')' '(' param_list ')'
   45           | '(' '*' IDENTIFIER ')' '(' ')'

   46 initializer: assignment_expr
   47            | '{' initializer_list '}'
   48            | '{' initializer_list ',' '}'

   49 initializer_list: initializer
   50                 | initializer_list ',' initializer

   51 type_qualifier: CONST
   52               | VOLATILE

   53 type_spec: INT
   54          | FLOAT
   55          | CHAR
   56          | VOID
   57          | DOUBLE
   58          | SHORT
   59          | LONG
   60          | UNSIGNED
   61          | SIGNED
   62          | type_qualifier type_spec
   63          | SHORT INT
   64          | LONG INT
   65          | LONG DOUBLE
   66          | UNSIGNED INT
   67          | UNSIGNED LONG
   68          | UNSIGNED CHAR
   69          | SIGNED INT
   70          | LONG LONG
   71          | LONG LONG INT
   72          | struct_decl
   73          | enum_decl

   74 storage_class_spec: AUTO
   75                   | REGISTER
   76                   | STATIC
   77                   | EXTERN
   78                   | INLINE

   79 storage_class_list: storage_class_spec
   80                   | storage_class_list storage_class_spec

   81 struct_decl: STRUCT IDENTIFIER '{' member_decl_list '}'
   82            | STRUCT '{' member_decl_list '}'
   83            | STRUCT IDENTIFIER
   84            | UNION IDENTIFIER '{' member_decl_list '}'
   85            | UNION '{' member_decl_list '}'
   86            | UNION IDENTIFIER

   87 member_decl_list: member_decl
   88                 | member_decl_list member_decl

   89 member_decl: type_spec declarator_list ';'
   90            | type_spec ';'

   91 enum_decl: ENUM IDENTIFIER '{' enumerator_list '}'
   92          | ENUM '{' enumerator_list '}'
   93          | ENUM IDENTIFIER

   94 enumerator_list: enumerator
   95                | enumerator_list ',' enumerator

   96 enumerator: IDENTIFIER
   97           | IDENTIFIER '=' INT_CONST

   98 compound_stmt: '{' '}'
   99              | '{' block_item_list '}'

  100 block_item_list: block_item
  101                | block_item_list block_item

  102 block_item: declaration
  103           | stmt

  104 stmt: compound_stmt
  105     | expr_stmt
  106     | selection_stmt
  107     | iteration_stmt
  108     | jump_stmt
  109     | labeled_stmt

  110 expr_stmt: ';'
  111          | expr ';'

  112 selection_stmt: IF '(' expr ')' stmt
  113               | IF '(' expr ')' stmt ELSE stmt

  114 $@8: ε

  115 selection_stmt: SWITCH '(' expr ')' $@8 '{' case_list '}'

  116 case_list: labeled_stmt
  117          | case_list labeled_stmt

  118 case_body_list: ε
  119               | case_body_list non_case_stmt

  120 labeled_stmt: CASE expr ':' case_body_list
  121             | DEFAULT ':' case_body_list

  122 non_case_stmt: compound_stmt
  123              | expr_stmt
  124              | selection_stmt
  125              | iteration_stmt
  126              | jump_stmt

  127 @9: ε

  128 $@10: ε

  129 iteration_stmt: WHILE '(' @9 expr ')' $@10 stmt

  130 @11: ε

  131 iteration_stmt: DO @11 stmt WHILE '(' expr ')' ';'
  132               | FOR '(' expr_stmt expr_stmt ')' stmt
  133               | FOR '(' expr_stmt expr_stmt expr ')' stmt
  134               | FOR '(' declaration expr_stmt ')' stmt
  135               | FOR '(' declaration expr_stmt expr ')' stmt

  136 jump_stmt: RETURN ';'
  137          | RETURN expr ';'
  138          | BREAK ';'
  139          | CONTINUE ';'

  140 expr: assignment_expr
  141     | expr ',' assignment_expr

  142 assignment_expr: conditional_expr
  143                | unary_expr '=' assignment_expr
  144                | unary_expr ASSIGN_OP assignment_expr

  145 conditional_expr: logical_or_expr
  146                 | logical_or_expr '?' expr ':' conditional_expr

  147 logical_or_expr: logical_and_expr

  148 @12: ε

  149 logical_or_expr: logical_or_expr OR_OP @12 logical_and_expr

  150 logical_and_expr: inclusive_or_expr

  151 @13: ε

  152 logical_and_expr: logical_and_expr AND_OP @13 inclusive_or_expr

  153 inclusive_or_expr: exclusive_or_expr
  154                  | inclusive_or_expr '|' exclusive_or_expr

  155 exclusive_or_expr: and_expr
  156                  | exclusive_or_expr '^' and_expr

  157 and_expr: equality_expr
  158         | and_expr '&' equality_expr

  159 equality_expr: relational_expr
  160              | equality_expr EQ_OP relational_expr
  161              | equality_expr NE_OP relational_expr

  162 relational_expr: shift_expr
  163                | relational_expr '<' shift_expr
  164                | relational_expr '>' shift_expr
  165                | relational_expr LE_OP shift_expr
  166                | relational_expr GE_OP shift_expr

  167 shift_expr: additive_expr
  168           | shift_expr LEFT_SHIFT additive_expr
  169           | shift_expr RIGHT_SHIFT additive_expr

  170 additive_expr: multiplicative_expr
  171              | additive_expr '+' multiplicative_expr
  172              | additive_expr '-' multiplicative_expr

  173 multiplicative_expr: unary_expr
  174                    | multiplicative_expr '*' unary_expr
  175                    | multiplicative_expr '/' unary_expr
  176                    | multiplicative_expr '%' unary_expr

  177 unary_expr: postfix_expr
  178           | INC_OP unary_expr
  179           | DEC_OP unary_expr
  180           | '-' unary_expr
  181           | '+' unary_expr
  182           | '!' unary_expr
  183           | '~' unary_expr
  184           | '*' unary_expr
  185           | '&' unary_expr
  186           | SIZEOF unary_expr
  187           | SIZEOF '(' type_spec ')'

  188 postfix_expr: primary_expr
  189             | postfix_expr '[' expr ']'

  190 $@14: ε

  191 postfix_expr: postfix_expr '(' $@14 ')'

  192 $@15: ε

  193 postfix_expr: postfix_expr '(' $@15 arg_list ')'
  194             | postfix_expr '.' IDENTIFIER
  195             | postfix_expr ARROW IDENTIFIER
  196             | postfix_expr INC_OP
  197             | postfix_expr DEC_OP

  198 primary_expr: IDENTIFIER
  199             | INT_CONST
  200             | FLOAT_CONST
  201             | CHAR_CONST
  202             | STRING_LITERAL
  203             | '(' expr ')'

  204 arg_list: assignment_expr
  205         | arg_list ',' assignment_expr


