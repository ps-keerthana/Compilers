Grammar

    0 $accept: program $end

    1 program: translation_unit

    2 translation_unit: external_decl
    3                 | translation_unit external_decl

    4 external_decl: function_def
    5              | declaration

    6 function_def: function_header compound_stmt

    7 function_header: type_spec IDENTIFIER '(' param_list ')'
    8                | type_spec IDENTIFIER '(' ')'
    9                | storage_class_list type_spec IDENTIFIER '(' param_list ')'
   10                | storage_class_list type_spec IDENTIFIER '(' ')'

   11 param_list: param_decl
   12           | param_list ',' param_decl
   13           | ELLIPSIS
   14           | param_list ',' ELLIPSIS

   15 param_decl: type_spec declarator
   16           | type_spec
   17           | storage_class_list type_spec declarator

   18 declaration: type_spec declarator_list ';'
   19            | storage_class_list type_spec declarator_list ';'
   20            | type_spec ';'
   21            | storage_class_list type_spec ';'
   22            | TYPEDEF type_spec declarator_list ';'

   23 declarator_list: declarator
   24                | declarator_list ',' declarator

   25 declarator: IDENTIFIER
   26           | '*' IDENTIFIER
   27           | IDENTIFIER '[' INT_CONST ']'
   28           | IDENTIFIER '[' ']'
   29           | IDENTIFIER '=' initializer
   30           | '*' IDENTIFIER '=' initializer
   31           | '(' '*' IDENTIFIER ')' '(' param_list ')'
   32           | '(' '*' IDENTIFIER ')' '(' ')'

   33 initializer: assignment_expr
   34            | '{' initializer_list '}'
   35            | '{' initializer_list ',' '}'

   36 initializer_list: initializer
   37                 | initializer_list ',' initializer

   38 type_qualifier: CONST
   39               | VOLATILE

   40 type_spec: INT
   41          | FLOAT
   42          | CHAR
   43          | VOID
   44          | DOUBLE
   45          | SHORT
   46          | LONG
   47          | UNSIGNED
   48          | SIGNED
   49          | type_qualifier type_spec
   50          | SHORT INT
   51          | LONG INT
   52          | LONG DOUBLE
   53          | UNSIGNED INT
   54          | UNSIGNED LONG
   55          | UNSIGNED CHAR
   56          | SIGNED INT
   57          | LONG LONG
   58          | LONG LONG INT
   59          | struct_decl
   60          | enum_decl

   61 storage_class_spec: AUTO
   62                   | REGISTER
   63                   | STATIC
   64                   | EXTERN
   65                   | INLINE

   66 storage_class_list: storage_class_spec
   67                   | storage_class_list storage_class_spec

   68 struct_decl: STRUCT IDENTIFIER '{' member_decl_list '}'
   69            | STRUCT '{' member_decl_list '}'
   70            | STRUCT IDENTIFIER
   71            | UNION IDENTIFIER '{' member_decl_list '}'
   72            | UNION '{' member_decl_list '}'
   73            | UNION IDENTIFIER

   74 member_decl_list: member_decl
   75                 | member_decl_list member_decl

   76 member_decl: type_spec declarator_list ';'

   77 enum_decl: ENUM IDENTIFIER '{' enumerator_list '}'
   78          | ENUM '{' enumerator_list '}'
   79          | ENUM IDENTIFIER

   80 enumerator_list: enumerator
   81                | enumerator_list ',' enumerator

   82 enumerator: IDENTIFIER
   83           | IDENTIFIER '=' INT_CONST

   84 compound_stmt: '{' '}'
   85              | '{' block_item_list '}'

   86 block_item_list: block_item
   87                | block_item_list block_item

   88 block_item: declaration
   89           | stmt

   90 stmt: compound_stmt
   91     | expr_stmt
   92     | selection_stmt
   93     | iteration_stmt
   94     | jump_stmt
   95     | labeled_stmt

   96 expr_stmt: ';'
   97          | expr ';'

   98 selection_stmt: IF '(' expr ')' stmt
   99               | IF '(' expr ')' stmt ELSE stmt
  100               | SWITCH '(' expr ')' '{' case_list '}'

  101 non_case_stmt: compound_stmt
  102              | expr_stmt
  103              | selection_stmt
  104              | iteration_stmt
  105              | jump_stmt

  106 case_list: ε
  107          | case_list labeled_stmt

  108 case_body_list: ε
  109               | case_body_list non_case_stmt

  110 labeled_stmt: CASE expr ':' case_body_list
  111             | DEFAULT ':' case_body_list
  112             | IDENTIFIER ':' stmt

  113 iteration_stmt: WHILE '(' expr ')' stmt
  114               | DO stmt WHILE '(' expr ')' ';'
  115               | FOR '(' expr_stmt expr_stmt ')' stmt
  116               | FOR '(' expr_stmt expr_stmt expr ')' stmt
  117               | FOR '(' declaration expr_stmt ')' stmt
  118               | FOR '(' declaration expr_stmt expr ')' stmt

  119 jump_stmt: RETURN ';'
  120          | RETURN expr ';'
  121          | BREAK ';'
  122          | CONTINUE ';'

  123 expr: assignment_expr
  124     | expr ',' assignment_expr

  125 assignment_expr: conditional_expr
  126                | unary_expr '=' assignment_expr
  127                | unary_expr ASSIGN_OP assignment_expr

  128 conditional_expr: logical_or_expr
  129                 | logical_or_expr '?' expr ':' conditional_expr

  130 logical_or_expr: logical_and_expr
  131                | logical_or_expr OR_OP logical_and_expr

  132 logical_and_expr: inclusive_or_expr
  133                 | logical_and_expr AND_OP inclusive_or_expr

  134 inclusive_or_expr: exclusive_or_expr
  135                  | inclusive_or_expr '|' exclusive_or_expr

  136 exclusive_or_expr: and_expr
  137                  | exclusive_or_expr '^' and_expr

  138 and_expr: equality_expr
  139         | and_expr '&' equality_expr

  140 equality_expr: relational_expr
  141              | equality_expr EQ_OP relational_expr
  142              | equality_expr NE_OP relational_expr

  143 relational_expr: shift_expr
  144                | relational_expr '<' shift_expr
  145                | relational_expr '>' shift_expr
  146                | relational_expr LE_OP shift_expr
  147                | relational_expr GE_OP shift_expr

  148 shift_expr: additive_expr
  149           | shift_expr LEFT_SHIFT additive_expr
  150           | shift_expr RIGHT_SHIFT additive_expr

  151 additive_expr: multiplicative_expr
  152              | additive_expr '+' multiplicative_expr
  153              | additive_expr '-' multiplicative_expr

  154 multiplicative_expr: unary_expr
  155                    | multiplicative_expr '*' unary_expr
  156                    | multiplicative_expr '/' unary_expr
  157                    | multiplicative_expr '%' unary_expr

  158 unary_expr: postfix_expr
  159           | INC_OP unary_expr
  160           | DEC_OP unary_expr
  161           | '-' unary_expr
  162           | '+' unary_expr
  163           | '!' unary_expr
  164           | '~' unary_expr
  165           | '*' unary_expr
  166           | '&' unary_expr
  167           | SIZEOF unary_expr
  168           | SIZEOF '(' type_spec ')'

  169 postfix_expr: primary_expr
  170             | postfix_expr '[' expr ']'
  171             | postfix_expr '(' ')'
  172             | postfix_expr '(' arg_list ')'
  173             | postfix_expr '.' IDENTIFIER
  174             | postfix_expr ARROW IDENTIFIER
  175             | postfix_expr INC_OP
  176             | postfix_expr DEC_OP

  177 primary_expr: IDENTIFIER
  178             | INT_CONST
  179             | FLOAT_CONST
  180             | CHAR_CONST
  181             | STRING_LITERAL
  182             | '(' expr ')'

  183 arg_list: assignment_expr
  184         | arg_list ',' assignment_expr


